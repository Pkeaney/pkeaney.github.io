---
import { Icon } from 'astro-icon/components';

const socials = [
  { href: 'https://github.com/Pkeaney', icon: 'ph:github-logo', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/patrickkeaney/', icon: 'ph:linkedin-logo', label: 'LinkedIn' },
  { href: 'https://x.com/ppk99__', icon: 'ph:x-logo', label: 'Twitter/X' },
];
---
  <div class="flex justify-center gap-4">
    {socials.map(({ href, icon, label }) => (
      <button 
  id="dark-theme-button"
  aria-label="Dark theme"
  class="group size-8 flex items-center justify-center rounded-full">
      <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}
        class="group-hover:stroke-black group-hover:dark:stroke-white transition-colors duration-300 ease-in-out">
        <Icon name={icon} class="w-6 h-6" />
      </a>
      </button>
    ))}
  </div>